{
  "private": true,
  "type": "module",
  "author": "SSen",
  "repository": "https://github.com/iamssen/solidjs2-web-prototype",
  "scripts": {
    "start": "echo 'Use Run and Debug panel of IDE instead'",
    "dev:app": "vite --config apps/app/vite.config.mts",
    "build:app": "vite build --config apps/app/vite.config.mts",
    "serve:app": "vite preview --config apps/app/vite.config.mts",
    "type-check": "tsc --version && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,css}\"",
    "lint": "eslint .",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,mts,cts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0",
      "vitest related"
    ],
    "**/*.{js,mjs,cjs,jsx}": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@solidjs/router": "next",
    "@solidjs/web": "next",
    "solid-js": "next"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@ssen/eslint-plugin-solid": "^2.0.0-next.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^72.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.1.5",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-solid": "next",
    "vitest": "^4.0.0"
  }
}
